  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, status, providerType])
}

model IntegrationEvent {
  id           String              @id @default(cuid())
  tenantId     String
  endpointId   String
  eventType    String
  payload      Json
  success      Boolean?
  responseCode Int?
  responseBody String?             @db.Text
  createdAt    DateTime            @default(now())
  endpoint     IntegrationEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([endpointId, createdAt])
}

model DocumentFolder {
  id          String                @id @default(cuid())
  tenantId    String
  parentId    String?
  name        String
  slug        String
  scope       DocumentAudience      @default(TENANT)
  branchId    String?
  employeeId  String?
  createdById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  documents   DocumentVaultRecord[]
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, parentId])
}

model DocumentVaultRecord {
  id           String           @id @default(cuid())
  tenantId     String
  folderId     String
  branchId     String?
  employeeId   String?
  category     String
  title        String
  description  String?          @db.Text
  fileUrl      String
  filePath     String
  mimeType     String?
  size         Int              @default(0)
  expiresAt    DateTime?
  visibility   DocumentAudience @default(TENANT)
  uploadedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  folder       DocumentFolder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, expiresAt])
  @@index([tenantId, category, createdAt])
  @@index([folderId, createdAt])
}

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  tenantId    String
  moduleKey   String
  periodKey   String
  branchId    String?
  metrics     Json
  createdById String?
  generatedAt DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, moduleKey, periodKey])
  @@index([tenantId, generatedAt])
}
